<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    
    <changeSet id="add-indexes-to-table-workout-set" author="Artem Makhalin">

        <createIndex tableName="workout_set" indexName="index_workout_exercise_id">

            <column name="workout_exercise_id"/>

        </createIndex>

        <createIndex tableName="workout_set" indexName="index_unique_workout_exercise_id_set_index" unique="true">

            <column name="workout_exercise_id"/>
            <column name="set_index"/>

        </createIndex>

    </changeSet>
    
</databaseChangeLog>