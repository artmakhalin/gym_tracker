<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-table-workout-set" author="Artem Makhalin">

        <createTable tableName="workout_set">

            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="set_index" type="int">
                <constraints nullable="false" unique="false"/>
            </column>

            <column name="reps" type="int">
                <constraints nullable="false" unique="false" checkConstraint="reps > 0"/>
            </column>

            <column name="weight" type="numeric(6,2)">
                <constraints nullable="false" unique="false" checkConstraint="weight >= 0"/>
            </column>

            <column name="rir" type="int">
                <constraints nullable="true" unique="false" checkConstraint="rir BETWEEN 0 AND 10"/>
            </column>

            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false" unique="false"/>
            </column>

            <column name="workout_exercise_id" type="bigint">
                <constraints nullable="false" unique="false"/>
            </column>

        </createTable>

    </changeSet>

</databaseChangeLog>