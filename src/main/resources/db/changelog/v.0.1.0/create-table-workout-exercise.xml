<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-table-workout-exercise" author="Artem Makhalin">

        <createTable tableName="workout_exercise">

            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="order_index" type="int">
                <constraints nullable="false" unique="false"/>
            </column>

            <column name="notes" type="varchar(500)">
                <constraints nullable="true" unique="false"/>
            </column>

            <column name="workout_id" type="bigint">
                <constraints nullable="false" unique="false"/>
            </column>

            <column name="exercise_id" type="bigint">
                <constraints nullable="false" unique="false"/>
            </column>

            <column name="source_template_exercise_id" type="bigint">
                <constraints nullable="true" unique="false"/>
            </column>

        </createTable>

    </changeSet>

</databaseChangeLog>