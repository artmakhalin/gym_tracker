<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    
    <changeSet id="add-indexes-to-table-workout" author="Artem Makhalin">

        <createIndex tableName="workout" indexName="index_app_user_id_performed_at">

            <column name="app_user_id"/>
            <column name="performed_at"/>

        </createIndex>

        <createIndex tableName="workout" indexName="index_workout_training_template_id">

            <column name="training_template_id"/>

        </createIndex>

    </changeSet>
    
</databaseChangeLog>